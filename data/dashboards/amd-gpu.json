{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-GPU telemetry for artemis (2× AMD Radeon AI PRO R9700) from the ROCm device-metrics-exporter. Legend keys by gpu_id; metric names may need adjusting for gfx1201 (see services/amd-gpu-metrics-exporter.tf).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Graphics + memory engine activity per GPU.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "expr": "gpu_gfx_activity",
          "legendFormat": "gfx {{ gpu_id }}",
          "refId": "A"
        },
        {
          "expr": "gpu_umc_activity",
          "legendFormat": "umc {{ gpu_id }}",
          "refId": "B"
        }
      ],
      "title": "GPU Utilization",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Edge / junction / memory temperature per GPU. Adjust series to whichever the R9700 emits.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "expr": "gpu_edge_temperature",
          "legendFormat": "edge {{ gpu_id }}",
          "refId": "A"
        },
        {
          "expr": "gpu_junction_temperature",
          "legendFormat": "junction {{ gpu_id }}",
          "refId": "B"
        },
        {
          "expr": "gpu_memory_temperature",
          "legendFormat": "mem {{ gpu_id }}",
          "refId": "C"
        }
      ],
      "title": "GPU Temperature",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Used vs total VRAM per GPU (R9700 = 32 GB each).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "min": 0,
          "unit": "decmbytes"
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "total.*" },
            "properties": [
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "expr": "gpu_used_vram",
          "legendFormat": "used {{ gpu_id }}",
          "refId": "A"
        },
        {
          "expr": "gpu_total_vram",
          "legendFormat": "total {{ gpu_id }}",
          "refId": "B"
        }
      ],
      "title": "GPU VRAM",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Board power draw per GPU.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "min": 0,
          "unit": "watt"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "max"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "expr": "gpu_power_usage",
          "legendFormat": "{{ gpu_id }}",
          "refId": "A"
        }
      ],
      "title": "GPU Power",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Clock frequencies (MHz) per GPU, by clock_type.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "min": 0,
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "12.4.1",
      "targets": [
        {
          "expr": "gpu_clock",
          "legendFormat": "{{ gpu_id }} {{ clock_type }}",
          "refId": "A"
        }
      ],
      "title": "GPU Clock (MHz)",
      "type": "timeseries"
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 42,
  "tags": [
    "homelab",
    "gpu",
    "artemis"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "AMD GPU (artemis)",
  "uid": "amd-gpu",
  "version": 1,
  "weekStart": ""
}
